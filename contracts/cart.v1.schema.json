{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ecommerce-lakehouse/contracts/cart/v1",
  "title": "CartEvent",
  "description": "Data contract v1 para eventos de carrinho (add/remove). Correlaciona com purchase por user_id para detectar abandono. Ver ADR-0006.",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "event_type", "cart_id", "user_id", "product_id", "quantity", "price", "currency", "timestamp"],
  "properties": {
    "event_id":   { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["add_to_cart", "remove_from_cart", "checkout"] },
    "cart_id":    { "type": "string", "format": "uuid", "description": "Identificador da sessão de carrinho." },
    "user_id":    { "type": "integer", "minimum": 1 },
    "product_id": { "type": "integer", "minimum": 1 },
    "quantity":   { "type": "integer", "minimum": 1, "maximum": 100 },
    "price":      { "type": "number", "exclusiveMinimum": 0 },
    "currency":   { "type": "string", "enum": ["BRL", "USD", "EUR"] },
    "timestamp":  { "type": "string", "format": "date-time", "description": "Event-time ISO-8601 UTC." },
    "channel":    { "type": "string", "enum": ["web", "ios", "android"] },
    "schema_version": { "type": "string", "const": "1.0.0" }
  }
}
